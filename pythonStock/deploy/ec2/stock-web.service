[Unit]
Description=Python Stock Streamlit Web
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/pythonStock/pythonStock
EnvironmentFile=/home/ubuntu/pythonStock/pythonStock/.env
ExecStart=/home/ubuntu/pythonStock/pythonStock/.venv/bin/streamlit run app.py --server.address 127.0.0.1 --server.port 8501 --server.headless true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
